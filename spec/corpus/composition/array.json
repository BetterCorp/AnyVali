{
  "suite": "array",
  "cases": [
    {
      "description": "accepts array of valid elements",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": { "kind": "array", "items": { "kind": "string" } },
        "definitions": {},
        "extensions": {}
      },
      "input": ["a", "b", "c"],
      "valid": true,
      "output": ["a", "b", "c"],
      "issues": []
    },
    {
      "description": "accepts empty array",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": { "kind": "array", "items": { "kind": "int" } },
        "definitions": {},
        "extensions": {}
      },
      "input": [],
      "valid": true,
      "output": [],
      "issues": []
    },
    {
      "description": "rejects non-array input",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": { "kind": "array", "items": { "kind": "string" } },
        "definitions": {},
        "extensions": {}
      },
      "input": "not an array",
      "valid": false,
      "output": null,
      "issues": [
        { "code": "invalid_type", "path": [], "expected": "array", "received": "string" }
      ]
    },
    {
      "description": "rejects array with invalid element",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": { "kind": "array", "items": { "kind": "int" } },
        "definitions": {},
        "extensions": {}
      },
      "input": [1, 2, "three"],
      "valid": false,
      "output": null,
      "issues": [
        { "code": "invalid_type", "path": [2], "expected": "int", "received": "string" }
      ]
    },
    {
      "description": "reports multiple invalid elements",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": { "kind": "array", "items": { "kind": "bool" } },
        "definitions": {},
        "extensions": {}
      },
      "input": [true, "yes", false, 1],
      "valid": false,
      "output": null,
      "issues": [
        { "code": "invalid_type", "path": [1], "expected": "bool", "received": "string" },
        { "code": "invalid_type", "path": [3], "expected": "bool", "received": "number" }
      ]
    }
  ]
}

{
  "suite": "object-required",
  "cases": [
    {
      "description": "accepts object with all required fields",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": {
          "kind": "object",
          "properties": {
            "name": { "kind": "string" },
            "age": { "kind": "int" }
          },
          "required": ["name", "age"],
          "unknownKeys": "reject"
        },
        "definitions": {},
        "extensions": {}
      },
      "input": { "name": "Alice", "age": 30 },
      "valid": true,
      "output": { "name": "Alice", "age": 30 },
      "issues": []
    },
    {
      "description": "rejects object missing a required field",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": {
          "kind": "object",
          "properties": {
            "name": { "kind": "string" },
            "age": { "kind": "int" }
          },
          "required": ["name", "age"],
          "unknownKeys": "reject"
        },
        "definitions": {},
        "extensions": {}

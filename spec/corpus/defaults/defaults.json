{
  "suite": "defaults",
  "cases": [
    {
      "description": "missing field gets default value",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": {
          "kind": "object",
          "properties": {
            "name": { "kind": "string" },
            "role": { "kind": "string", "default": "user" }
          },
          "required": ["name"],
          "unknownKeys": "reject"
        },
        "definitions": {},
        "extensions": {}
      },
      "input": { "name": "Alice" },
      "valid": true,
      "output": { "name": "Alice", "role": "user" },
      "issues": []
    },
    {
      "description": "present field is NOT overwritten by default",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": {
          "kind": "object",
          "properties": {
            "name": { "kind": "string" },
            "role": { "kind": "string", "default": "user" }
          },
          "required": ["name"],
          "unknownKeys": "reject"
        },
        "definitions": {},
        "extensions": {}
      },
      "input": { "name": "Alice", "role": "admin" },
      "valid": true,
      "output": { "name": "Alice", "role": "admin" },
      "issues": []
    },
    {
      "description": "defaulted value is validated",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": {
          "kind": "object",
          "properties": {
            "count": { "kind": "int", "min": 1, "default": 5 }
          },
          "required": [],
          "unknownKeys": "reject"
        },
        "definitions": {},
        "extensions": {}
      },
      "input": {},
      "valid": true,
      "output": { "count": 5 },
      "issues": []
    },
    {
      "description": "invalid default produces default_invalid issue",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": {
          "kind": "object",
          "properties": {
            "count": { "kind": "int", "min": 10, "default": 5 }
          },
          "required": [],
          "unknownKeys": "reject"
        },
        "definitions": {},
        "extensions": {}
      },
      "input": {},
      "valid": false,
      "output": null,
      "issues": [
        { "code": "default_invalid", "path": ["count"], "expected": "10", "received": "5" }
      ]
    },
    {
      "description": "null is not treated as absent for defaults",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": {
          "kind": "object",
          "properties": {
            "value": { "kind": "nullable", "schema": { "kind": "string" }, "default": "fallback" }
          },
          "required": [],
          "unknownKeys": "reject"
        },
        "definitions": {},
        "extensions": {}
      },
      "input": { "value": null },
      "valid": true,
      "output": { "value": null },
      "issues": []
    },
    {
      "description": "default with boolean value",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": {
          "kind": "object",
          "properties": {
            "active": { "kind": "bool", "default": true }
          },
          "required": [],
          "unknownKeys": "reject"
        },
        "definitions": {},
        "extensions": {}
      },
      "input": {},
      "valid": true,
      "output": { "active": true },
      "issues": []
    }
  ]
}

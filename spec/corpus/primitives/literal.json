{
  "suite": "literal",
  "cases": [
    {
      "description": "accepts matching string literal",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": { "kind": "literal", "value": "hello" },
        "definitions": {},
        "extensions": {}
      },
      "input": "hello",
      "valid": true,
      "output": "hello",
      "issues": []
    },
    {
      "description": "rejects non-matching string literal",
      "schema": {
        "anyvaliVersion": "1.0",
        "schemaVersion": "1",
        "root": { "kind": "literal", "value": "hello" },
        "definitions": {},
        "extensions": {}
      },
      "input": "world",
      "valid": false,
      "output": null,
      "issues": [
        { "code": "invalid_literal", "path": [], "expected": "hello", "received": "world" }
      ]
    },
    {

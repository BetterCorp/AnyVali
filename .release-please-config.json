{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "pull-request-title-pattern": "chore${scope}: release ${component} ${version}",
  "packages": {
    ".": {
      "component": "anyvali",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/js": {
      "component": "js",
      "release-type": "node",
      "package-name": "@anyvali/js",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/python": {
      "component": "python",
      "release-type": "python",
      "package-name": "anyvali",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/go": {
      "component": "go",
      "release-type": "go",
      "package-name": "github.com/BetterCorp/AnyVali/sdk/go",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/java": {
      "component": "java",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/rust": {
      "component": "rust",
      "release-type": "rust",
      "package-name": "anyvali",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/php": {
      "component": "php",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/ruby": {
      "component": "ruby",
      "release-type": "ruby",
      "package-name": "anyvali",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/kotlin": {
      "component": "kotlin",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/csharp": {
      "component": "csharp",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk/cpp": {
      "component": "cpp",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    }
  }
}

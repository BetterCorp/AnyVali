<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>AnyVali</RootNamespace>
    <Version>0.1.7</Version> <!-- x-release-please-version -->
    <PackageId>AnyVali</PackageId>
    <Description>Native validation with portable schema interchange</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://anyvali.com</PackageProjectUrl>
    <RepositoryUrl>https://github.com/BetterCorp/AnyVali</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="AnyVali.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
